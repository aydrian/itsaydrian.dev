---
import ThemeToggle from './ThemeToggle.astro';

const navLinks = [
  { href: '/about',    label: 'About' },
  { href: '/articles', label: 'Articles' },
  { href: '/projects', label: 'Projects' },
  { href: '/speaking', label: 'Speaking' },
  { href: '/uses',     label: 'Uses' },
];

const path = Astro.url.pathname;
---

<header
  class="sticky top-0 z-50 backdrop-blur-md"
  style="background: var(--nav-bg); border-bottom: 1px solid var(--border);"
>
  <nav
    class="max-w-4xl mx-auto px-6 h-16 flex items-center justify-between gap-8"
    aria-label="Main navigation"
  >
    <!-- Logo -->
    <a
      href="/"
      class="text-base font-semibold tracking-tight shrink-0 transition-opacity hover:opacity-80"
      style="font-family: 'Fraunces', serif; color: var(--text);"
    >
      Aydrian Howard
    </a>

    <!-- Desktop links -->
    <ul class="hidden sm:flex items-center gap-1" role="list">
      {navLinks.map(link => {
        const isActive = path === link.href || path.startsWith(link.href + '/');
        return (
          <li>
            <a
              href={link.href}
              class={`relative px-3 py-1.5 text-sm rounded-md transition-colors duration-150 ${
                isActive
                  ? 'font-medium'
                  : 'hover:opacity-80'
              }`}
              style={isActive
                ? 'color: var(--accent); background: var(--bg-secondary);'
                : 'color: var(--text-muted);'
              }
            >
              {link.label}
            </a>
          </li>
        );
      })}
    </ul>

    <!-- Right: theme toggle + mobile menu -->
    <div class="flex items-center gap-2 shrink-0">
      <ThemeToggle />

      <!-- Mobile: hamburger (checkbox hack — no JS needed) -->
      <label class="sm:hidden flex items-center justify-center w-9 h-9 rounded-lg cursor-pointer" style="color: var(--text-muted); background: var(--bg-secondary);" aria-label="Toggle menu">
        <input type="checkbox" id="mobile-menu-toggle" class="sr-only peer" />
        <!-- hamburger icon -->
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 peer-checked:hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
        <!-- close icon -->
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 hidden peer-checked:block" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </label>
    </div>
  </nav>

  <!-- Mobile dropdown -->
  <div
    id="mobile-menu"
    class="sm:hidden hidden border-t px-6 py-4"
    style="border-color: var(--border); background: var(--bg);"
  >
    <ul class="flex flex-col gap-1" role="list">
      {navLinks.map(link => {
        const isActive = path === link.href || path.startsWith(link.href + '/');
        return (
          <li>
            <a
              href={link.href}
              class="block px-3 py-2 text-sm rounded-md transition-colors"
              style={isActive
                ? 'color: var(--accent); background: var(--bg-secondary); font-weight: 500;'
                : 'color: var(--text-muted);'
              }
            >
              {link.label}
            </a>
          </li>
        );
      })}
    </ul>
  </div>
</header>

<script>
  const toggle = document.getElementById('mobile-menu-toggle') as HTMLInputElement | null;
  const menu = document.getElementById('mobile-menu');
  toggle?.addEventListener('change', () => {
    menu?.classList.toggle('hidden', !toggle.checked);
  });
</script>

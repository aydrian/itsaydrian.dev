---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import profileImage from '../assets/aydrian+atticus25.png';

const allArticles = await getCollection('articles', ({ data }) => !data.draft);
const featuredArticles = allArticles
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const workHistory = [
  {
    role: 'Senior Developer Advocate',
    company: 'Okta',
    period: '2025 – Present',
    description: 'Building developer experiences and community around identity and access management. Creating content, delivering talks, and helping developers integrate Okta securely and confidently.',
  },
  {
    role: 'Product Principal & Evangelist',
    company: 'Tabnine',
    period: '2023 – 2025',
    description: 'Evangelized AI-powered developer tooling. Translated complex AI capabilities into approachable narratives for developer audiences through content, demos, and community engagement.',
  },
  {
    role: 'Developer Advocate',
    company: 'Cockroach Labs',
    period: '2021 – 2023',
    description: 'Championed CockroachDB adoption with developers. Built integrations, delivered technical talks, and grew the community around distributed SQL.',
  },
  {
    role: 'Staff Developer Advocate',
    company: 'Courier',
    period: '2020 – 2021',
    description: 'Helped developers build better notification experiences. Created educational content and shaped the developer experience around product-triggered communications.',
  },
  {
    role: 'Senior Developer Advocate',
    company: 'MongoDB',
    period: '2017 – 2020',
    description: 'Helped build the Developer Relations team. Organized community events including the NYC MongoDB User Group, and created technical content to drive adoption.',
  },
  {
    role: 'Senior Developer Advocate',
    company: 'SparkPost',
    period: '2015 – 2017',
    description: 'One of the first developer advocates at SparkPost. Built and maintained the NYC developer community, maintained the Node.js client library, and helped shape the direction of the DevRel team.',
  },
];
---

<Layout title="Aydrian Howard — Builder. Creator. Advocate.">

  <!-- ─── Hero ──────────────────────────────────────────── -->
  <section class="max-w-4xl mx-auto px-6 pt-16 pb-20">
    <div class="flex flex-col-reverse md:flex-row items-center md:items-start gap-10 md:gap-16">

      <!-- Text -->
      <div class="flex-1 min-w-0">
        <p class="section-label mb-4">Welcome</p>

        <h1
          class="text-4xl sm:text-5xl font-semibold leading-tight mb-4"
          style="font-family: 'Fraunces', serif; color: var(--text);"
        >
          Aydrian Howard
        </h1>

        <p
          class="text-xl font-medium mb-5"
          style="color: var(--accent);"
        >
          Builder. Creator. Advocate.
        </p>

        <p class="text-base leading-relaxed mb-8 max-w-prose" style="color: var(--text-muted);">
          Developer advocate, engineer, and community builder based in New York, NY.
          Hoosier at heart, Corgi dad by choice. I help developers build great things
          with TypeScript — and I'm learning Rust one error message at a time.
        </p>

        <!-- CTAs -->
        <div class="flex items-center gap-3 flex-wrap">
          <a
            href="https://github.com/aydrian"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 px-4 py-2 rounded-lg text-sm font-medium transition-all duration-200 hover:opacity-90 hover:-translate-y-0.5"
            style="background: var(--accent); color: #fff;"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/></svg>
            GitHub
          </a>
          <a
            href="/articles"
            class="inline-flex items-center gap-1.5 px-4 py-2 rounded-lg text-sm font-medium transition-all duration-200 hover:-translate-y-0.5"
            style="background: var(--bg-secondary); color: var(--text); border: 1px solid var(--border);"
          >
            Read my writing
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        </div>
      </div>

      <!-- Photo -->
      <div class="shrink-0">
        <div class="relative" style="width: 220px;">
          <div
            class="absolute inset-0 rounded-2xl -rotate-2 scale-[0.98]"
            style="background: var(--accent); opacity: 0.15;"
          ></div>
          <Image
            src={profileImage}
            alt="Aydrian Howard with his corgi Atticus"
            width={440}
            height={440}
            class="relative rounded-2xl w-full h-auto shadow-xl object-cover"
            style="aspect-ratio: 1/1;"
            loading="eager"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- ─── Featured Articles ──────────────────────────────── -->
  <section class="max-w-4xl mx-auto px-6 pb-20">
    <div class="flex items-baseline justify-between mb-8">
      <div>
        <p class="section-label">Writing</p>
        <h2 class="text-2xl font-semibold" style="font-family: 'Fraunces', serif;">Recent Articles</h2>
      </div>
      <a
        href="/articles"
        class="text-sm font-medium transition-colors hover:underline"
        style="color: var(--accent);"
      >
        All articles →
      </a>
    </div>

    {featuredArticles.length > 0 ? (
      <ul class="flex flex-col gap-3">
        {featuredArticles.map(article => (
          <li>
            <a href={`/articles/${article.id}`} class="card group flex flex-col sm:flex-row sm:items-center gap-3 p-5 no-underline block">
              <div class="flex-1 min-w-0">
                <h3 class="font-medium text-base group-hover:text-[var(--accent)] transition-colors" style="color: var(--text);">
                  {article.data.title}
                </h3>
                <p class="text-sm mt-1 line-clamp-2" style="color: var(--text-muted);">
                  {article.data.description}
                </p>
                {article.data.tags.length > 0 && (
                  <ul class="flex flex-wrap gap-1.5 mt-3">
                    {article.data.tags.map(tag => <li class="tag">{tag}</li>)}
                  </ul>
                )}
              </div>
              <time
                class="text-xs shrink-0"
                datetime={article.data.pubDate.toISOString()}
                style="color: var(--text-faint);"
              >
                {article.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
              </time>
            </a>
          </li>
        ))}
      </ul>
    ) : (
      <p class="text-sm" style="color: var(--text-muted);">Articles coming soon.</p>
    )}
  </section>

  <!-- ─── Work History ───────────────────────────────────── -->
  <section class="max-w-4xl mx-auto px-6 pb-20">
    <p class="section-label">Experience</p>
    <h2 class="text-2xl font-semibold mb-10" style="font-family: 'Fraunces', serif;">Work History</h2>

    <ol class="pl-0 list-none">
      {workHistory.map(job => (
        <li class="timeline-item">
          <time class="text-xs font-semibold tracking-wide" style="color: var(--accent);">{job.period}</time>
          <h3 class="text-base font-semibold mt-1" style="color: var(--text);">{job.role}</h3>
          <p class="text-sm font-medium" style="color: var(--text-muted);">{job.company}</p>
          <p class="text-sm mt-2 max-w-prose leading-relaxed" style="color: var(--text-faint);">{job.description}</p>
        </li>
      ))}
    </ol>
  </section>

</Layout>
